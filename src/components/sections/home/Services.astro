---
// components
import Container from "../../elements/Container.astro";
import Heading from "../../elements/Heading.astro";
import Dropdown from "../../elements/Dropdown.astro";
import ContainerBottom from "../../elements/ContainerBottom.astro";

// content
const services = [
    {
        title: "Cross-Platform Apps",
        text: "We build native-quality apps for both iOS and Android from a single codebase. Whether it's a game, a utility, or something in between, we ship polished apps that feel right at home on any device."
    },
    {
        title: "Scalable Websites & Backends",
        text: "Every great app needs a solid foundation. We design and build fast, reliable backends and marketing sites that scale with your user base — from day one to millions of downloads."
    },
    {
        title: "Branding & UI/UX Design",
        text: "From app icons to full brand identities, we craft cohesive visual experiences that stand out in crowded app stores. Our designs are user-first, making sure every interaction feels intuitive and intentional."
    },
    {
        title: "Go-to-Market Strategy",
        text: "Launching an app is only half the battle. We help with App Store optimization, launch planning, and growth strategies to make sure your app finds its audience and keeps them coming back."
    },
]
---

<Container variant={'md'}>
    <Heading tagName="h2" tagSize="h2" class="text-center">Services</Heading>
    <div class="flex flex-col gap-4">
        <Container class="flex flex-col gap-4 p-6 border-3 border-base-900">
            {
                services.map((service, index) => (
                    <Dropdown title=`${index + 1}. ${service.title}` text={service.text} />  
                ))
            }       
        </Container>
        <ContainerBottom />    
    </div>

</Container>