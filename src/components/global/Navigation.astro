---
// components
import Link from "../elements/Link.astro";

// links
const navLinks = [
    { title: "Home", href: "/" },
    { title: "Projects", href: "/projects" },
    { title: "About", href: "/about" },
    { title: "Contact", href: "/contact" }
]
---

<nav class="flex justify-end py-8 fixed top-0 right-6 left-0 z-50">
    <!-- Desktop Nav -->
    <ul class="hidden md:flex gap-8">
        {
            navLinks.map((link, index) => (
                <li>
                    <Link href={link.href} variant={'nav'}>{index + 1}. {link.title}</Link>
                </li>
            ))
        }
    </ul>
    <!-- Mobile Nav -->
    <div class="md:hidden">
        <button id="open-nav" aria-label="Open Navigation">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#FF5F00" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <div class="hidden fixed inset-0 bg-base-100 z-50" id="mobile-nav">
            <div class="flex flex-col items-center justify-center h-full">
                <button id="close-nav" aria-label="Close Navigation" class="absolute top-6 right-6 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#FF5F00" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
                </button>
                <ul class="flex flex-col p-6 gap-5 md:hidden text-center">
                    {
                        navLinks.map((link) => (
                            <li><Link href={link.href} variant={'nav'}>{link.title}</Link></li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </div>
</nav>

<script>
    const mobileNav = document.querySelector('#mobile-nav') as HTMLUListElement;
    const openBtn = document.querySelector('#open-nav') as HTMLButtonElement;
    const closeBtn = document.querySelector('#close-nav') as HTMLButtonElement;

    openBtn.addEventListener("click", () => {
        mobileNav.classList.remove('hidden');
    })

    closeBtn.addEventListener("click", () => {
        mobileNav.classList.add('hidden');
    })
</script>