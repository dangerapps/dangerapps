---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
    href: string;
    variant: "inline" | "button" | "nav";
    newWindow?: boolean;
}

const { href: rawHref, variant, newWindow = false, class: className, ...rest} = Astro.props;

// Prefix internal links with base URL
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = rawHref.startsWith('/') ? `${base}${rawHref}` : rawHref;

// common styling for all link variants
const baseStyle = "text-base-900"

// styling for each variant
const variantStyle = {
    inline: "font-mono font-semibold hover:text-base-900 underline underline-offset-3 text-neon-teal",
    button: "font-grunge px-6 py-2 border-2 border-neon-teal hover:bg-neon-teal hover:text-base-100 text-24 uppercase tracking-wide text-neon-teal",
    nav: "font-grunge hover:text-base-900 text-24 uppercase underline underline-offset-4 decoration-2 tracking-wide text-neon-orange"
}
---

<a href={href} 
    class:list={[baseStyle, variantStyle[variant], className]}
    target={newWindow ? "_blank" : undefined}
    rel={newWindow ? "noopener noreferrer" : undefined}
    {...rest}>
    <slot />
</a>
